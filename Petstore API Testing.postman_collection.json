    {
      "name": "Assignment 2 - POST Requests",
      "item": [
        {
          "name": "Create Pet - Validate Response Data",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test(\"Verify status code is 200 OK\", function () {\r",
                  "    pm.response.to.have.status(200);\r",
                  "});\r",
                  "\r",
                  "\r",
                  "let requestData = JSON.parse(pm.request.body.raw);\r",
                  "pm.test(\"Verify pet name in response\", function(){\r",
                  "    var response = pm.response.json();\r",
                  "    pm.expect(response.name).to.eql(\"Doggie\");\r",
                  "});\r",
                  "\r",
                  ""
                ],
                "type": "text/javascript",
                "packages": {},
                "requests": {}
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [],
            "body": {
              "mode": "raw",
              "raw": "{\r\n    \"id\": 9999,\r\n    \"name\": \"Doggie\",\r\n    \"status\": \"available\"\r\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "{{url}}/pet",
              "host": [
                "{{url}}"
              ],
              "path": [
                "pet"
              ]
            },
            "description": "This request creates a new pet in the Petstore API using a POST method.\n\nRequest Body:  \n\\- id: Unique identifier for the pet  \n\\- name: Name of the pet  \n\\- status: Availability status of the pet.\n\nValidations:  \n\\- Verify the API returns a status code of 200 OK  \n\\- Verify the response contains the same pet name as sent in the request"
          },
          "response": []
        }
      ]
    },
